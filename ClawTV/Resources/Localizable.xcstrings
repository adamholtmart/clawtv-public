    "ClawTV is a player. It does not provide, host, or sell any TV channels or content.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ClawTV es un reproductor. No proporciona, aloja ni vende canales de TV ni contenido."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "ClawTV é um reprodutor. Não fornece, hospeda nem vende canais de TV ou conteúdo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ClawTV est un lecteur. Il ne fournit, n'héberge ni ne vend aucune chaîne ou contenu TV."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ClawTV مشغل فقط. لا يوفر أو يستضيف أو يبيع أي قنوات تلفزيونية أو محتوى."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "ClawTV bir oynatıcıdır. Hiçbir TV kanalı veya içerik sağlamaz, barındırmaz veya satmaz."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ClawTV ist ein Player. Es stellt keine TV-Kanäle oder Inhalte bereit, hostet oder verkauft diese."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "ClawTV este un player. Nu furnizează, nu găzduiește și nu vinde canale TV sau conținut."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "ClawTV to odtwarzacz. Nie dostarcza, nie hostuje ani nie sprzedaje kanałów telewizyjnych ani treści."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ClawTV è un player. Non fornisce, ospita né vende canali TV o contenuti."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "ClawTV is een speler. Het biedt geen tv-kanalen of inhoud aan, host of verkoopt deze niet."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ClawTV — это плеер. Он не предоставляет, не хостит и не продаёт телеканалы или контент."
          }
        }
      }
    },
    "I understand and confirm I have the right to view the content I'm about to load.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Entiendo y confirmo que tengo derecho a ver el contenido que voy a cargar."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Entendo e confirmo que tenho o direito de visualizar o conteúdo que estou prestes a carregar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je comprends et confirme que j'ai le droit de regarder le contenu que je vais charger."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أفهم وأؤكد أن لدي الحق في مشاهدة المحتوى الذي سأحمله."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yüklemek üzere olduğum içeriği izleme hakkına sahip olduğumu anlıyor ve onaylıyorum."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich verstehe und bestätige, dass ich das Recht habe, die Inhalte anzusehen, die ich laden möchte."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Înțeleg și confirm că am dreptul de a viziona conținutul pe care urmează să îl încarc."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozumiem i potwierdzam, że mam prawo do oglądania treści, które zamierzam załadować."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Capisco e confermo di avere il diritto di visualizzare il contenuto che sto per caricare."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ik begrijp en bevestig dat ik het recht heb om de inhoud te bekijken die ik ga laden."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я понимаю и подтверждаю, что имею право просматривать загружаемый контент."
          }
        }
      }
    },
